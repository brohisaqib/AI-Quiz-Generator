FROM python:3.12-slim

WORKDIR /app

# ── Python dependencies ────────────────────────────────────────────────────
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# ── Application code ───────────────────────────────────────────────────────
COPY . .

EXPOSE 8501

# ── Flask server entrypoint ───────────────────────────────────────────────────
CMD ["python", "frontend/app.py"]

