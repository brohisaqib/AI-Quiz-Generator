# ─── Flask Settings ────────────────────────────────────────────────────────
FLASK_APP=app.py
FLASK_ENV=development
PORT=5000
HOST=0.0.0.0

# ─── Groq API Configuration ───────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_EVAL_MODEL=llama-3.1-8b-instant
GROQ_WHISPER_MODEL=whisper-large-v3

# ─── File Upload Settings ─────────────────────────────────────────────────
# Folders are relative to project root (or use absolute paths)
UPLOAD_FOLDER=uploads
TEMP_FOLDER=temp
OUTPUT_FOLDER=outputs
LOG_FOLDER=logs

# File size limit in bytes (default 100MB)
MAX_UPLOAD_SIZE=104857600

# ─── Database ─────────────────────────────────────────────────────────────
# PostgreSQL Database settings (used by Docker Compose db service)
POSTGRES_USER=quizapp
POSTGRES_PASSWORD=quizpass
POSTGRES_DB=ai_quiz_generator

# PostgreSQL Database URL (used by Flask app)
# Note: For local non-Docker development, use "localhost" instead of "db"
#   e.g. DATABASE_URL=postgresql://quizapp:quizpass@localhost:5432/ai_quiz_generator
DATABASE_URL=postgresql://quizapp:quizpass@db:5432/ai_quiz_generator

# ─── Authentication Settings ──────────────────────────────────────────────
# JWT signing secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ACCESS_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=30

# ─── CORS ─────────────────────────────────────────────────────────────────
# In production, restrict to your actual frontend domain/IP.
# Example: ALLOWED_ORIGINS=https://myapp.example.com
# For local dev: ALLOWED_ORIGINS=*
ALLOWED_ORIGINS=*

# ─── Backend URL (used by Streamlit frontend) ─────────────────────────────
# Local dev:
BACKEND_URL=http://127.0.0.1:5000
# Docker Compose (set automatically via docker-compose.yml environment block):
# BACKEND_URL=http://backend:5000
